# ============================================================================
# openagent-api - Environment Template (.env.example)
# ============================================================================
#
# HOW TO USE THIS FILE:
#   1. Copy this file to .env in the same directory:
#        cp .env.example .env
#   2. Fill in the SIX required values below.
#   3. Bring the stack up:
#        docker-compose up -d --build
#
# .env IS NEVER COMMITTED. .env.example is. The .gitignore in this repo
# excludes .env explicitly. If you ever see a real key in a commit, treat it
# as compromised and rotate immediately.
#
# KEY GENERATION:
#   The six required values fall into two groups based on which other
#   service's value they must match. Generate them as follows:
#
#   OPENAGENT_API_KEY and INFRA_API_KEY:
#     python -c "import secrets; print(secrets.token_hex(32))"
#   Each call returns a 64-character hex string with 256 bits of entropy.
#
#   LOGGER_API_KEY and LOGGER_HMAC_SECRET (must match openagent-logger's
#   .env byte-for-byte — see those sections below):
#     python -c "import secrets; print(secrets.token_urlsafe(48))"
#   openagent-logger's README documents this generation command, so the
#   value generated there is the one to copy into this file. For each of
#   these two, match the convention used by the service on the OTHER side
#   of the boundary.
# ============================================================================


# ----------------------------------------------------------------------------
# OPENAGENT_API_KEY — INBOUND SECRET (REQUIRED)
# ----------------------------------------------------------------------------
# Validated by openagent-api on every /chat and /health request.
# openagent-frontend MUST send this exact value as the X-API-Key header.
#
# This is the secret that authorises the frontend to talk to openagent-api.
# It does NOT authorise openagent-api to talk to openagent-infra — that's
# INFRA_API_KEY below. It does NOT authorise openagent-api to talk to
# openagent-logger — that's LOGGER_API_KEY below. Three independent secrets
# at three independent boundaries (compartmentalized auth).
#
# openagent-frontend's .env must contain the SAME value as OPENAGENT_API_KEY
# (or whatever variable name the frontend uses for its outbound key).
#
# Generate a fresh one for each deployment:
#   python -c "import secrets; print(secrets.token_hex(32))"
OPENAGENT_API_KEY=


# ----------------------------------------------------------------------------
# INFRA_API_KEY — OUTBOUND SECRET TO openagent-infra (REQUIRED)
# ----------------------------------------------------------------------------
# Sent by openagent-api as the X-API-Key header on every call to
# openagent-infra. MUST match openagent-infra's API_KEY env var
# byte-for-byte.
#
# This key never leaves openagent-api's environment. The frontend never sees
# it. openagent-logger never sees it. If it leaks, only openagent-api →
# openagent-infra is compromised; the frontend and logger boundaries stay
# intact.
#
# This is intentionally a different value from OPENAGENT_API_KEY. Two
# independent secrets give you separate blast radii and independent rotation.
# See the api.py header for the full reasoning, or README's "Security Model"
# section.
#
# Generate a fresh one independent of OPENAGENT_API_KEY:
#   python -c "import secrets; print(secrets.token_hex(32))"
INFRA_API_KEY=


# ----------------------------------------------------------------------------
# OPENAGENT_INFRA_URL — UPSTREAM ADDRESS FOR openagent-infra (REQUIRED)
# ----------------------------------------------------------------------------
# Base URL of the openagent-infra service. No trailing slash.
#
# Pick the value that matches your deployment topology:
#
#   1. Everything on host (no Docker for openagent-api or openagent-infra):
#        OPENAGENT_INFRA_URL=http://localhost:8002
#
#   2. openagent-api in Docker, openagent-infra on host (DEFAULT for dev):
#        OPENAGENT_INFRA_URL=http://host.docker.internal:8002
#
#   3. openagent-api and openagent-infra both in Docker on a shared network
#      (see docker-compose.yml "SHARED NETWORK" notes):
#        OPENAGENT_INFRA_URL=http://openagent-infra:8002
#
#   4. External openagent-infra (cloud / remote host):
#        OPENAGENT_INFRA_URL=https://infra.your-domain.com
#
# Port 8002 is the port convention for openagent-infra.
OPENAGENT_INFRA_URL=http://host.docker.internal:8002


# ----------------------------------------------------------------------------
# LOGGER_URL — UPSTREAM ADDRESS FOR openagent-logger (REQUIRED)
# ----------------------------------------------------------------------------
# Base URL of the openagent-logger service. No trailing slash.
#
# openagent-logger is the capture layer that receives operational events
# (request_received, upstream_call, upstream_error, stream_complete) and full
# conversation captures from openagent-api. openagent-api refuses to boot if
# this value is missing (lifespan startup validation).
#
# Pick the value that matches your deployment topology (same four-topology
# shape as OPENAGENT_INFRA_URL above):
#
#   1. Everything on host (no Docker for openagent-api or openagent-logger):
#        LOGGER_URL=http://localhost:8003
#
#   2. openagent-api in Docker, openagent-logger on host (DEFAULT for dev —
#      openagent-logger runs in its own Docker stack on the host and
#      openagent-api reaches it via the host's port mapping):
#        LOGGER_URL=http://host.docker.internal:8003
#
#   3. openagent-api and openagent-logger both in Docker on a shared network
#      (see docker-compose.yml "SHARED NETWORK" notes):
#        LOGGER_URL=http://openagent-logger:8003
#
#   4. External openagent-logger (cloud / remote host):
#        LOGGER_URL=https://logger.your-domain.com
#
# Port 8003 is the canonical openagent-logger port per the port convention
# (8000=frontend, 8001=openagent-api, 8002=openagent-infra,
# 8003=openagent-logger).
LOGGER_URL=http://host.docker.internal:8003


# ----------------------------------------------------------------------------
# LOGGER_API_KEY — TRANSPORT SECRET FOR openagent-logger (REQUIRED)
# ----------------------------------------------------------------------------
# Sent by openagent-api as the X-API-Key header on every event POST to
# openagent-logger. MUST match openagent-logger's LOGGER_API_KEY env var
# byte-for-byte. If the two values diverge, every event submission returns
# HTTP 401 from openagent-logger and the event is dropped by openagent-api's
# fire-and-forget queue (with a WARNING log line per failed event).
#
# Independent of LOGGER_HMAC_SECRET below. The two secrets protect against
# different threats and rotate on independent schedules:
#   - LOGGER_API_KEY rotation: invalidates network access on the
#     openagent-api → openagent-logger boundary but does NOT invalidate HMAC
#     signatures stored on existing rows. Safe to rotate frequently with a
#     brief coordinated cutover.
#   - LOGGER_HMAC_SECRET rotation: invalidates payload-integrity verification
#     for existing rows. Plan carefully — see the LOGGER_HMAC_SECRET section
#     below.
#
# This key never leaves openagent-api's environment. The frontend never sees
# it. openagent-infra never sees it. If it leaks, only openagent-api →
# openagent-logger is compromised; the other three boundaries stay intact
# (compartmentalized auth per README's "Security Model" section).
#
# Generation: openagent-logger's convention is token_urlsafe(48) — copy the
# value FROM openagent-logger's .env rather than generating a new one here.
# The whole point of "MUST match byte-for-byte" is that openagent-logger is
# the source of truth for this value.
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# (Use that ONLY for fresh generation from scratch; for any existing
# openagent-logger deployment, copy the existing value from its .env.)
LOGGER_API_KEY=


# ----------------------------------------------------------------------------
# LOGGER_HMAC_SECRET — PAYLOAD-SIGNING SECRET FOR openagent-logger (REQUIRED)
# ----------------------------------------------------------------------------
# HMAC-SHA256 key used by openagent-api to sign every event payload before
# submission to openagent-logger. MUST match openagent-logger's
# LOGGER_HMAC_SECRET env var byte-for-byte. If the two diverge,
# openagent-logger returns HTTP 401 ("Invalid HMAC signature") on every event
# and openagent-api's fire-and-forget queue drops it (with a WARNING log line
# per failed event).
#
# The signature is computed over the canonical string:
#   {request_id}|{client_timestamp_iso}|{event_type}|sha256(payload_json)
# per openagent-logger DATASHEET §2.1. See src/client/logger.py for the
# byte-for-byte implementation contract (sort_keys=True,
# separators=(",", ":"), default=str, ensure_ascii=False).
#
# IMPORTANT — rotation has long-term implications:
#   The signature is stored on every row in openagent-logger's database (in
#   the hmac_signature column). This means downstream consumers (auditors,
#   any reader) can re-verify event integrity offline using only
#   LOGGER_HMAC_SECRET — they do not need trust in the original transport
#   call. THIS PROPERTY MAKES THE ROTATION POLICY FOR LOGGER_HMAC_SECRET
#   DIFFERENT FROM LOGGER_API_KEY:
#     - LOGGER_API_KEY rotation: cheap. Invalidates only future wire-level
#       access. Existing rows unaffected.
#     - LOGGER_HMAC_SECRET rotation: expensive. Invalidates the
#       offline-verifiability of EVERY pre-rotation row. Plan carefully and
#       coordinate with any downstream consumers. Typical pattern: never
#       rotate unless the old value is known compromised; for a
#       known-compromised rotation, document the cutover timestamp so
#       downstream consumers know which secret to use for which rows.
#
# Independent of LOGGER_API_KEY above (different value, different threat
# model, different rotation schedule — by design).
#
# Generation: openagent-logger's convention is token_urlsafe(48). As with
# LOGGER_API_KEY, copy the value FROM openagent-logger's .env rather than
# generating a new one here. openagent-logger's repo is the source of truth
# for this value.
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# (Fresh generation only; for an existing openagent-logger deployment, copy
# the existing value from its .env.)
LOGGER_HMAC_SECRET=


# ============================================================================
# OPTIONAL TUNABLES — uncomment to override defaults
# ============================================================================

# ----------------------------------------------------------------------------
# OPENAGENT_FRONTEND_URL — extra CORS origin (OPTIONAL)
# ----------------------------------------------------------------------------
# Adds an additional allowed origin to the CORS middleware. Use this when
# openagent-frontend is deployed at a custom domain (Render, Fly, Cloudflare,
# etc.) that isn't already in the built-in origin list. Empty / unset means
# "use built-in origins only" (localhost variants and the openagent-frontend
# Docker service name).
# OPENAGENT_FRONTEND_URL=https://openagent.your-domain.com


# ----------------------------------------------------------------------------
# OPENAGENT_LOG_LEVEL — log verbosity (OPTIONAL)
# ----------------------------------------------------------------------------
# One of: DEBUG | INFO | WARNING | ERROR | CRITICAL
# Default: INFO
# DEBUG is noisy — emits per-request detail. Use for development only. DEBUG
# also enables per-event LoggerClient drain success messages; expect roughly
# 4-5 additional DEBUG lines per /chat call when set to DEBUG.
# OPENAGENT_LOG_LEVEL=INFO


# ----------------------------------------------------------------------------
# OPENAGENT_UPSTREAM_CONNECT_TIMEOUT — TCP connect timeout (OPTIONAL)
# ----------------------------------------------------------------------------
# Seconds to wait for the TCP connection to openagent-infra. Short by design
# — if openagent-infra is unreachable, fail fast.
# Default: 10.0
# Note: this controls the openagent-infra boundary only. The openagent-logger
# boundary has its own connect timeout (5s) hard-coded in
# src/client/logger.py because fire-and-forget emissions should fail even
# faster than the hot-path stream.
# OPENAGENT_UPSTREAM_CONNECT_TIMEOUT=10.0


# ----------------------------------------------------------------------------
# OPENAGENT_UPSTREAM_READ_TIMEOUT — read timeout during streaming (OPTIONAL)
# ----------------------------------------------------------------------------
# Seconds to wait for the next chunk from openagent-infra during a stream.
# Default is unbounded ("none") because two distinct upstream conditions can
# legitimately take many minutes:
#   1. Provider cold-start. A scale-to-zero serverless worker spins down when
#      idle. The first request after a period of inactivity waits for the
#      worker to spin up before any token can stream back.
#   2. High-effort reasoning generation. At reasoning_effort=high the model
#      can think for 1-3 minutes before producing visible output (per
#      openagent-infra's datasheet generation timing table).
# Setting a finite value would kill either of these legitimate waits.
# Accepted values: a number (e.g. "300") or "none" / "null" / "" for
# unbounded.
# OPENAGENT_UPSTREAM_READ_TIMEOUT=none


# ----------------------------------------------------------------------------
# OPENAGENT_HEALTH_TIMEOUT — upstream /health probe timeout (OPTIONAL)
# ----------------------------------------------------------------------------
# Seconds to wait for openagent-infra's /health response. Short because the
# frontend polls /health every 3 seconds and must never block.
# Default: 5.0
# OPENAGENT_HEALTH_TIMEOUT=5.0


# ----------------------------------------------------------------------------
# OPENAGENT_BIO_PATH — override bio.txt path (OPTIONAL)
# ----------------------------------------------------------------------------
# Path inside the container to the persona file. Override only if you mount
# bio.txt from a volume rather than baking it into the image.
# Default: /app/src/prompt/bio.txt
# OPENAGENT_BIO_PATH=/app/src/prompt/bio.txt


# ----------------------------------------------------------------------------
# OPENAGENT_LOGGER_QUEUE_MAX_SIZE — LoggerClient queue capacity (OPTIONAL)
# ----------------------------------------------------------------------------
# Maximum pending events in openagent-api's LoggerClient queue before the
# drop-oldest overflow policy kicks in. The queue is in-process, in-memory;
# it does not persist across restarts. When the queue is full, the oldest
# pending event is evicted with a WARNING log line to make room for the new
# event.
#
# When to raise this: you anticipate longer sustained openagent-logger
# outages and want to retain more pending events in memory until the capture
# layer comes back.
# When to lower this: memory is tight on the container; you prefer to
# fail-faster on event loss with louder warnings.
#
# Default: 1000
#
# Memory cost is roughly proportional to queue size × average event size.
# Typical events are a few KB (small ops_event); the largest possible event
# is a ~1 MB conversation_capture (output_text capped at 1_000_000 chars per
# openagent-logger DATASHEET §2.1). 1000 events at average size is well under
# 100 MB; worst-case all-large 1000-event queue is ~1 GB, which is far more
# than openagent-api typically consumes in normal operation.
#
# This is an openagent-api-side operational tunable. It does NOT need to match
# anything in openagent-logger's .env — openagent-logger has no corresponding
# setting.
# OPENAGENT_LOGGER_QUEUE_MAX_SIZE=1000
